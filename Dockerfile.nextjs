FROM node:20-alpine

WORKDIR /app

RUN apk add --no-cache python3 make g++ \
  && corepack enable \
  && corepack prepare pnpm@10.33.4 --activate

# Install dependencies with pnpm.
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml .npmrc ./
RUN pnpm install --frozen-lockfile

# Copy application.
COPY . .

# Build Next.js app.
RUN pnpm build

EXPOSE 3000

CMD ["pnpm", "dev"]
