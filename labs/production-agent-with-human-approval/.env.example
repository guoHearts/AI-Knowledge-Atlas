# Production Agent with Human Approval Configuration
# Copy this file to .env and customize for your environment

# Agent Server Configuration
HOST=0.0.0.0
AGENT_PORT=8002
DASHBOARD_PORT=8003
DEBUG=true

# Redis Configuration (for task queuing)
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Task and Approval Configuration
MAX_TASK_RETRIES=3
APPROVAL_TIMEOUT_HOURS=24
CHECKPOINT_INTERVAL=300
MAX_CONCURRENT_TASKS=5

# Webhook Configuration (for external notifications)
WEBHOOK_BASE_URL=http://localhost:3000/api
APPROVAL_WEBHOOK_PATH=/approval/notify
REJECTION_WEBHOOK_PATH=/approval/reject

# Notification Configuration
EMAIL_NOTIFICATIONS_ENABLED=false
EMAIL_SMTP_SERVER=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_USERNAME=your-email@gmail.com
EMAIL_PASSWORD=your-app-password

# Logging Configuration
LOG_LEVEL=INFO
AUDIT_LOG_PATH=logs/audit.log
TASK_LOG_PATH=logs/tasks.log

# Dashboard Configuration
DASHBOARD_SECRET_KEY=your-dashboard-secret-key
SESSION_TIMEOUT_MINUTES=60

# Security Configuration
API_KEY_REQUIRED=true
AGENT_API_KEY=your-agent-api-key
DASHBOARD_API_KEY=your-dashboard-api-key

# Checkpoint and Rollback Configuration
CHECKPOINT_STORAGE=redis  # redis or file
MAX_CHECKPOINTS_PER_TASK=10
CHECKPOINT_TTL_HOURS=168  # 1 week

# Task Priority Configuration
PRIORITY_LEVELS=low,normal,high,critical
DEFAULT_PRIORITY=normal
HIGH_PRIORITY_ESCALATION_HOURS=2

# Health Check Configuration
HEALTH_CHECK_INTERVAL=30
TASK_MONITORING_INTERVAL=60