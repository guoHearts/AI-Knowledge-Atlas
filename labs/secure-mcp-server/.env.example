# Secure MCP Server Configuration
# Copy this file to .env and customize for your environment

# API Configuration
API_KEY=your-secure-api-key-change-this-in-production
HOST=0.0.0.0
PORT=8000

# Security Settings
ALLOWED_TOOLS=calculator,weather,search
MAX_EXECUTION_TIME=30
MAX_INPUT_LENGTH=1000

# Logging Configuration
LOG_LEVEL=INFO
AUDIT_LOG_PATH=logs/audit.log
ENABLE_AUDIT_LOGGING=true

# Prompt Injection Defense
ENABLE_PROMPT_INJECTION_DEFENSE=true
BLOCKED_PATTERNS=rm -rf,drop table,delete from,;,",',

# Tool-specific Configuration
CALCULATOR_ENABLED=true
WEATHER_API_KEY=optional-weather-api-key
SEARCH_ENABLED=true

# CORS Settings (for web clients)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Rate Limiting (optional)
ENABLE_RATE_LIMITING=false
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60
